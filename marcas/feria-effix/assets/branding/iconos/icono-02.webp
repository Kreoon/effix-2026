    <style>
        #btn-mas {
            display: none;
        }
        .container {
            position: fixed;
            z-index: 1000;
            bottom: 60px;
            right: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            align-items: flex-end;
        }

        .redes a {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 8px;
            text-decoration: none;
            transition: all 0.3s ease-in-out;
            margin-bottom: 10px;
        }
        
        .icono-redes {
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 22px;
            color: #fff;
            transition: color 0.3s ease-in-out, transform 0.3s ease-in-out;
        }
        .texto-redes {
            background-color: #f5f7f9;
            padding: 8px 12px;
            border-radius: 25px;
            color: #43474e;
            font-size: 14px;
            font-weight: bold;
            white-space: nowrap;
            box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease-in-out;
        }
        /* Colores originales */
        .redes-boletas .icono-redes {
            background: linear-gradient(#4286C6, #263164);
        }
        .redes-stand .icono-redes {
            background: linear-gradient(#1E90FF, #004AAD); /* Azul diferente */
        }
        .redes-whatsapp .icono-redes {
            background: linear-gradient(#2db742, #0a721a);
        }
        /* Hover: Cambio de color del icono */
        .redes a:hover .icono-redes i {
            color: #263164; /* Azul oscuro */
        }
        .redes-whatsapp:hover .icono-redes i {
            color: #0a721a; /* Verde oscuro */
        }
        .redes a:hover .texto-redes {
            transform: scale(1.05);
            box-shadow: 0px 6px 12px rgba(0, 0, 0, 0.3);
        }
        @media (max-width: 768px) {
            .container {
                right: 10px;
                bottom: 60px;
            }
            .icono-redes {
                width: 45px;
                height: 45px;
                font-size: 20px;
            }
            .texto-redes {
                font-size: 13px;
            }
        }
        @media (max-width: 520px) {
            .container {
                right: 5px;
                bottom: 70px;
            }
            .icono-redes {
                width: 40px;
                height: 40px;
                font-size: 18px;
            }
            .texto-redes {
                font-size: 12px;
            }
        }
    </style><meta name="generator" content="Elementor 3.35.7; features: e_font_icon_svg; settings: css_print_method-internal, google_font-enabled, font_display-swap">
